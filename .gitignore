# CUSTODIAN - Unified .gitignore
# Project root and all sub-projects

# =======================
# GODOT (all Godot projects)
# =======================
.godot/
.import/
.android/
.mono/
.export_cmake/
export_presets.cfg
export.cfg
*.translation
icon.svg.import
# Keep .tres, .tscn, .gd files tracked - these are source code

# =======================
# PYTHON (python-sim)
# =======================
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
ENV.bak/

# =======================
# GODOT ASSETS (external - placeholder dirs)
# =======================
PixelPlanets/
PixelSpace/

# =======================
# OS / EDITOR
# =======================
.DS_Store
Thumbs.db
*.swp
*.swo
*~
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# =======================
# LOCAL TOOLING / DIAGNOSTICS
# =======================
*.log
*.tmp
*.bak
*.bak-*
*.cache
.tmp/
.temp/
scripts/.tmp/
.nvimlog
nvimspector*.json
vscode/*.json
.vscode-test/

# =======================
# MCP / LOCAL PLUGINS
# =======================
custodian/addons/godot_mcp/.cache/

# =======================
# BUILD OUTPUTS
# =======================
build/
dist/
*.egg-info/
*.whl
out/

# =======================
# IDE
# =======================
.idea/
.vscode/
*.code-workspace
*.sublime-*
.ijsettings/
*.iml

# =======================
# TESTING
# =======================
coverage/
.coverage
htmlcov/
.omx/

# =======================
# NODE.JS / JAVASCRIPT
# =======================
node_modules/
package-lock.json

# =======================
# CUSTODIAN SPECIFIC
# =======================
# Local environment overrides (create personal .env files but don't track them)
.env
.env.local
.env.*.local
# Editor history/state
custodian/.editorrescache

# =======================
# RCLONE SYNC (if used)
# =======================
rclone-git-sync.sh

# =======================
# AI generated context packets
# =======================
.ai/
repomix-output.*
