#!/bin/sh

set -e

# ──────────────────────────────────────────────
# 1. Block commits that include forbidden files
# ──────────────────────────────────────────────
forbidden_pattern='^(auth\.json|internal_storage\.json|history\.jsonl|olddauth\.json|shell_snapshots/|log/)$'

staged_paths=$(git diff --cached --name-only)
if [ -n "$staged_paths" ]; then
  forbidden_match=$(printf "%s\n" "$staged_paths" | grep -E "$forbidden_pattern" || true)
  if [ -n "$forbidden_match" ]; then
    echo "Commit blocked: forbidden files or directories staged." >&2
    echo "Remove these paths from the commit:" >&2
    echo "$forbidden_match" >&2
    exit 1
  fi
fi

# ──────────────────────────────────────────────
# 2. Warn about .aseprite / .ase source files
#    outside content/_aseprite/
# ──────────────────────────────────────────────
# This hook used to move files during commit. Hooks should not rewrite the
# working tree unexpectedly, so this is now advisory only.
if [ -d "custodian/content" ]; then
  content_aseprite_files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^custodian/content/.*\.(aseprite|ase)$' | grep -v '/_aseprite/' || true)

  if [ -n "$content_aseprite_files" ]; then
    content_aseprite_count=$(printf "%s\n" "$content_aseprite_files" | wc -l | tr -d ' ')
    echo "Warning: staged .aseprite/.ase source files are outside content/_aseprite/." >&2
    echo "Consider moving them after this commit if they are intended source assets. Showing first 25 of $content_aseprite_count:" >&2
    printf "%s\n" "$content_aseprite_files" | sed -n '1,25p' >&2
  fi
fi

# ──────────────────────────────────────────────
# 3. Optional warning: untracked, unignored files
# ──────────────────────────────────────────────
warn_dirs="log sessions shell_snapshots"
if [ -n "$warn_dirs" ]; then
  untracked=$(git ls-files -o --exclude-standard $warn_dirs 2>/dev/null || true)
  if [ -n "$untracked" ]; then
    echo "Warning: untracked files exist under log/, sessions/, or shell_snapshots/." >&2
    echo "Consider adding them to .gitignore or removing them:" >&2
    echo "$untracked" >&2
  fi
fi

exit 0
