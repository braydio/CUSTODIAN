#!/bin/sh
command -v git-lfs >/dev/null 2>&1 || {
  printf >&2 "\n%s\n\n" "Warning: Git LFS is configured but 'git-lfs' was not found on your path; skipping LFS post-commit hook."
  exit 0
}
git lfs post-commit "$@" || printf >&2 "\n%s\n\n" "Warning: git lfs post-commit failed; commit was created."

# Optional Google Drive sync. Keep commits local and fast by default.
REPO_DIR="$(git rev-parse --show-toplevel)"
if [ "${CUSTODIAN_SYNC_AFTER_COMMIT:-0}" = "1" ] && [ -x "$REPO_DIR/rclone-git-sync.sh" ]; then
  log_dir="$REPO_DIR/.git/hooks-logs"
  mkdir -p "$log_dir"
  nohup "$REPO_DIR/rclone-git-sync.sh" > "$log_dir/rclone-git-sync.log" 2>&1 &
  echo "Started background Google Drive sync; log: $log_dir/rclone-git-sync.log"
else
  echo "Skipping Google Drive sync. Set CUSTODIAN_SYNC_AFTER_COMMIT=1 to run it in the background."
fi

# Gentle reminder after commits.

cat <<'MSG'
Post-commit reminder:
Did this commit change behavior or decisions? If yes, update docs/_ai_context/DEVLOG.md.
MSG

exit 0
