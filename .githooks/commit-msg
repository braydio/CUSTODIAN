#!/bin/sh

set -e

msg_file="$1"
if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
  exit 0
fi

# Allow override via commit message
if grep -q "\[no-docs\]" "$msg_file"; then
  exit 0
fi

changed_code=$(git diff --cached --name-only | grep -E '\.(py|js)$' || true)
changed_docs=$(git diff --cached --name-only | grep -E 'ai/(CURRENT_STATE|CONTEXT)\.md' || true)

if [ -n "$changed_code" ] && [ -z "$changed_docs" ]; then
  echo "Warning: code changed but tracking docs were not detected." >&2
  echo "If this was intentional, no action is required; use [no-docs] to suppress this warning." >&2
fi

exit 0
