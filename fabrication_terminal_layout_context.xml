		GothicCompoundAssets.RESOURCES["blackwood"],
		GothicCompoundAssets.RESOURCES["ruin_scrap"],
	]

	for i in range(min(cfg.exterior_resource_count, positions.size())):
		var pos := positions[i]
		if not _in_map(ctx, pos):
			continue
		if ctx.is_blocked(pos):
