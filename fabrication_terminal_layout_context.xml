# Developer Observatory Instrumentation

Status: in_progress
Feature type: tooling / debug instrumentation
Runtime target: Godot 4.x
Primary runtime path: `custodian/game/systems/debug/dev_observatory.gd`
Autoload path: `res://game/systems/debug/dev_observatory.gd`
Last updated: 2026-07-13

## Summary

This pass expands event coverage for the existing `DevObservatory` autoload. It does not add a new debug system, starter bundle, duplicate autoload, or alternate `res://scripts/debug/...` path.

The active runtime already owns the observability foundation:

- `DevObservatory` for counters, gauges, warnings, and recent event overlay data
- `WorldHistory` for durable runtime event memory
- `WorldStateGraph` for keyed world truth
- `SimulationInterestManager` for distance-tier classification
- `SectorHeatmap` for spatial accumulation

## Instrumentation Added

Operator coverage:

- ranged shot success
- blocked muzzle shot outcome
- ranged fire failure reason
- loaded/reserve ammo gauges
- recoil gauge
- Field Patch start, cancel, and commit
- Field Patch remaining gauge
- dodge start
- iframe damage avoid
- incoming hit result analytics for parried, dodged, blocked, and damaged outcomes
- normalized player damage and death observatory helper usage

Enemy coverage:

- attack windup
- cancelled attack with no valid target
- melee whiff from range/arc validation
- resolved attack result with applied damage and parry/block/dodge flags
- assault state transition
- simulation tier change
- behavior profile setup and manual force hooks
- marine dash phase changes from windup through finish

DevObservatory live gauges:

- `fps`
- `node_count`
- `player_position`
- `player_health`
- `player_stamina`
- `player_loaded_ammo`
- `player_reserve_ammo`
- `active_enemies`
- `behavior_agents`
- `ambient_critters`
- `active_projectiles`

## Constraints

- No gameplay balance changes.
- No damage, timing, movement, AI decision, attack range, animation, or asset-path changes.
- Runtime owners keep gameplay authority; observability remains a passive sink.
- Use `has_method` and group lookups for live sampling so the observatory has no hard dependency on Operator or Enemy classes.

## Validation

Required checks:

```bash
cd custodian
godot --headless --quit
```

Path drift check:

```bash
grep -R "res://scripts/debug/dev_observatory.gd" -n .
```

The active autoload must remain:

```text
DevObservatory="*res://game/systems/debug/dev_observatory.gd"
```

Manual smoke:

1. Toggle the observatory overlay with F9.
2. Fire a ranged weapon.
3. Fire with the muzzle blocked against a wall.
4. Dodge.
5. Take a hit while dodging.
6. Block, parry, and take an enemy hit if available.
7. Kill an enemy.
8. Trigger a marine dash enemy if available.
9. Confirm events and gauges appear without duplicate autoloads.
</file>

<file path="custodian/tools/validation/fabrication_terminal_layout_smoke.gd">
extends SceneTree

const GAME_SCENE := preload("res://scenes/game.tscn")

var _failed := false


func _init() -> void:
	call_deferred("_run")


func _run() -> void:
	var game := GAME_SCENE.instantiate()
	root.add_child(game)
	await process_frame
	await process_frame

	var ui := game.get_node_or_null("UI")
	_require(ui != null, "Main game scene should expose UI node.")
	if ui == null:
		game.queue_free()
		_finish()
		return

	var terminal_panel := ui.get_node_or_null("TerminalPanel") as Control
	if terminal_panel != null:
		terminal_panel.visible = true
	ui.call("_set_terminal_page", "FABRICATION")
	ui.call("_set_terminal_widget_mode", "FABRICATION")
	ui.call("_render_terminal_fabrication_widgets")
	await process_frame
	await process_frame

	var fabrication_widgets := ui.find_child("FabricationWidgets", true, false) as Control
	_require(fabrication_widgets != null, "FabricationWidgets should exist.")
	_require(fabrication_widgets == null or fabrication_widgets.visible, "FabricationWidgets should be visible.")
	if fabrication_widgets != null:
		_check_no_visible_child_overflow(fabrication_widgets)

	for scroll in ui.find_children("*", "ScrollContainer", true, false):
		if not (scroll is ScrollContainer):
			continue
		var scroll_container := scroll as ScrollContainer
		if fabrication_widgets != null and (scroll_container == fabrication_widgets or fabrication_widgets.is_ancestor_of(scroll_container) or scroll_container.name == "MainContentScroll"):
			_require(
				scroll_container.horizontal_scroll_mode == ScrollContainer.SCROLL_MODE_DISABLED,
				"%s should have horizontal scroll disabled." % scroll_container.name
			)

	var recipe_scroll := ui.find_child("RecipeScroll", true, false) as ScrollContainer
	_require(recipe_scroll != null, "RecipeScroll should exist.")
	if recipe_scroll != null:
		_require(recipe_scroll.vertical_scroll_mode == ScrollContainer.SCROLL_MODE_AUTO, "RecipeScroll should allow vertical scrolling.")

	var action_row := ui.find_child("ActionRow", true, false) as Control
	_require(action_row != null, "ActionRow should exist.")
	if action_row != null:
		_require(action_row.size.y >= 40.0, "ActionRow should remain tall enough for buttons.")

	game.queue_free()
	await process_frame
	_finish()


func _check_no_visible_child_overflow(root_control: Control) -> void:
	var right_edge := root_control.global_position.x + root_control.size.x + 2.0
	for child in root_control.find_children("*", "Control", true, false):
		if not (child is Control):
			continue
		var control := child as Control
		if not control.is_visible_in_tree():
			continue
		var child_right := control.global_position.x + control.size.x
		_require(
			child_right <= right_edge,
			"%s exceeds FabricationWidgets width by %.1f px." % [control.name, child_right - right_edge]
		)


func _finish() -> void:
	if _failed:
		print("[FabricationTerminalLayoutSmoke] FAILED")
		quit(1)
		return
	print("[FabricationTerminalLayoutSmoke] PASS")
	quit(0)


func _require(condition: bool, message: String) -> void:
	if condition:
		return
	_failed = true
	push_error("[FabricationTerminalLayoutSmoke] " + message)
</file>

