{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 1000000
  },
  "output": {
    "filePath": ".ai/custodian-architecture.xml",
    "style": "xml",
    "compress": true,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": true,
    "topFilesLength": 40,
    "showLineNumbers": false,
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 100,
      "includeDiffs": false,
      "includeLogs": false
    }
  },
  "include": [
    "AGENTS.md",
    "AGENTS_ADDENDUM.md",
    "custodian/AGENTS.md",
    "custodian/project.godot",
    "custodian/autoload/**/*.gd",
    "custodian/game/**/*.gd",
    "custodian/game/**/*.tscn",
    "custodian/game/**/*.tres",
    "custodian/content/**/*.json",
    "custodian/content/**/*.md",
    "custodian/docs/**/*.md"
  ],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "custodian/addons/**",
      "custodian/docs/archive/**",
      "custodian/content/_aseprite/**",
      "custodian/content/sprites/**",
      "**/*.png",
      "**/*.png.import",
      "**/*.aseprite",
      "**/*.ase",
      "**/*.uid",
      ".ai/**"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
