[gd_scene load_steps=2 format=3]

[sub_resource type="LabelSettings" id="LabelSettings_damage"]
font_size = 24
font_color = Color(1, 0.9, 0.3, 1)
outline_size = 3
outline_color = Color(0, 0, 0, 1)

[sub_resource type="GDScript" id="GDScript_damage"]
script/source = "extends Label\n\nvar lifetime := 0.8\nvar float_height := 40.0\n\nfunc _ready() -> void:\n\tmodulate.a = 1.0\n\t\n\tvar tween := create_tween()\n\ttween.set_parallel(true)\n\ttween.tween_property(self, \"position:y\", position.y - float_height, lifetime).set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_QUAD)\n\ttween.tween_property(self, \"modulate:a\", 0.0, lifetime).set_delay(lifetime * 0.5)\n\ttween.tween_property(self, \"scale\", Vector2(1.3, 1.3), 0.15).set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_BACK)\n\ttween.tween_property(self, \"scale\", Vector2(1.0, 1.0), 0.2).set_delay(0.15)\n\t\n\tawait tween.finished\n\tqueue_free()\n"

[node name="DamagePopup" type="Label"]
offset_right = 40.0
offset_bottom = 26.0
text = "0"
label_settings = SubResource("LabelSettings_damage")
horizontal_alignment = 1
vertical_alignment = 1
script = SubResource("GDScript_damage")