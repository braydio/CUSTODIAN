; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CUSTODIAN"
run/main_scene="res://scenes/game.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameState="*res://game/systems/core/state/game_state.gd"
GameStats="*res://game/systems/core/state/game_stats.gd"
ARRNManager="*res://game/systems/core/systems/arrn/arrn_manager.gd"
DevConsole="*uid://ccoijpiv8l45j"
DebugBus="*res://debug/debug_bus.gd"
DebugSnapshotCollector="*res://debug/debug_snapshot_collector.gd"
DebugImguiConsole="*res://debug/debug_imgui_console.gd"
BetterTerrain="*uid://6gj10atdkou3"
InventoryManager="*res://game/systems/core/systems/inventory_manager.gd"
VaultManager="*res://game/systems/core/systems/vault_manager.gd"
CognitiveState="*res://game/systems/cognitive/cognitive_state_system.gd"
ResourceLedger="*res://autoload/resource_ledger.gd"
BuildInventory="*res://autoload/build_inventory.gd"
FabPipeline="*res://autoload/fab_pipeline.gd"
_mcp_game_helper="*res://addons/godot_ai/runtime/game_helper.gd"
DebugCore="*uid://ctmkncwpk2qma"
CommandRegistry="*uid://ce5ap1y1kwavq"
GameConsoleManager="*uid://dsr8e7vkd3scc"
MusicManager="*res://autoload/music_manager.gd"
WorldEventMemory="*res://game/systems/core/state/world_event_memory.gd"
NoiseEventBus="*res://game/systems/stealth/noise_event_bus.gd"
DevObservatory="*res://game/systems/debug/dev_observatory.gd"
WorldStateGraph="*res://game/systems/world/world_state_graph.gd"
WorldHistory="*res://game/systems/world/world_history.gd"
SimulationInterestManager="*res://game/systems/simulation/simulation_interest_manager.gd"
SectorHeatmap="*res://game/systems/world/sector_heatmap.gd"
ImGui="*uid://csvdmevoaejje"

[dev_console]

console_title_label="CONSOLE"
console_use_default_commands=true
console_use_command_history=true
console_background_transparency=0.9

[audio]

driver/buffer_size=512

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/better-terrain/plugin.cfg", "res://addons/dear-imgui-godot/plugin.cfg", "res://addons/debug_console/plugin.cfg", "res://addons/dev-console/plugin.cfg", "res://addons/fightengine/plugin.cfg", "res://addons/godot_ai/plugin.cfg", "res://addons/godotdev_nvim_node_copy/plugin.cfg", "res://addons/indie_game_components/plugin.cfg", "res://addons/shader_library/plugin.cfg")

